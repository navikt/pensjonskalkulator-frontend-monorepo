{
	"name": "@pensjonskalkulator-frontend-monorepo/intern",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:q2": "concurrently \"vite --mode backend\" \"nodemon --watch server/ --exec 'pnpm build:server && NODE_ENV=development node --env-file=.env.development-q2 dist/server/server.js'\"",
		"build": "tsc && vite build",
		"build:server": "tsc -p tsconfig.server.json",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "echo 'No tests yet' && exit 0",
		"test:e2e": "playwright test --project=chromium",
		"pw:open": "playwright test --ui --project=chromium",
		"pw:test": "playwright test --project=chromium",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@navikt/oasis": "4.1.4",
		"express": "5.2.1",
		"express-rate-limit": "8.2.2",
		"http-proxy-middleware": "3.0.5",
		"unleash-client": "6.10.1",
		"winston": "3.19.0"
	},
	"devDependencies": {
		"@navikt/aksel-icons": "8.9.1",
		"@navikt/ds-css": "8.9.1",
		"@navikt/ds-react": "8.9.1",
		"@pensjonskalkulator-frontend-monorepo/api": "workspace:*",
		"@pensjonskalkulator-frontend-monorepo/mocks": "workspace:*",
		"@pensjonskalkulator-frontend-monorepo/sanity": "workspace:*",
		"@pensjonskalkulator-frontend-monorepo/types": "workspace:*",
		"@pensjonskalkulator-frontend-monorepo/utils": "workspace:*",
		"@playwright/test": "catalog:",
		"@portabletext/react": "catalog:",
		"@tanstack/react-query": "5.90.20",
		"@vitejs/plugin-react": "5.1.2",
		"clsx": "catalog:",
		"concurrently": "catalog:",
		"date-fns": "catalog:",
		"msw": "catalog:",
		"nodemon": "3.1.11",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "7.71.2",
		"react-intl": "catalog:",
		"vite": "7.3.2"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
