{
	"name": "pensjonskalkulator-frontend-monorepo",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@11.1.1",
	"type": "module",
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev": "pnpm --filter @pensjonskalkulator-frontend-monorepo/intern dev",
		"dev:intern": "pnpm --filter @pensjonskalkulator-frontend-monorepo/intern dev",
		"dev:ekstern": "pnpm --filter @pensjonskalkulator-frontend-monorepo/ekstern dev",
		"dev:sanity": "pnpm --dir packages/sanity exec sanity dev -- --port 3333",
		"build": "pnpm -r build",
		"build:intern": "pnpm --filter @pensjonskalkulator-frontend-monorepo/intern build",
		"build:ekstern": "pnpm --filter @pensjonskalkulator-frontend-monorepo/ekstern build",
		"test": "pnpm -r test",
		"lint": "pnpm --filter @pensjonskalkulator-frontend-monorepo/ekstern lint && pnpm --filter @pensjonskalkulator-frontend-monorepo/intern lint",
		"lint:fix": "pnpm --filter @pensjonskalkulator-frontend-monorepo/ekstern lint:fix && pnpm --filter @pensjonskalkulator-frontend-monorepo/intern lint:fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "pnpm -r typecheck",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules pnpm-lock.yaml",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix --max-warnings=0 --no-warn-ignored"
		],
		"*.{ts,tsx,js,jsx,css,json,md,yaml,yml}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@navikt/ds-react": "catalog:",
		"@sanity/color-input": "catalog:",
		"@sanity/document-internationalization": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"sanity": "catalog:",
		"sanity-plugin-internationalized-array": "catalog:",
		"styled-components": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "9.39.2",
		"@pensjonskalkulator-frontend-monorepo/types": "workspace:*",
		"@playwright/test": "catalog:",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@vitest/eslint-plugin": "1.4.2",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"eslint": "9.39.2",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-sonarjs": "3.0.4",
		"globals": "17.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"prettier": "3.8.1",
		"typescript": "catalog:",
		"typescript-eslint": "8.54.0",
		"vitest": "catalog:"
	}
}
